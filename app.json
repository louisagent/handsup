{
  "expo": {
    "name": "handsup.live",
    "slug": "handsup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "handsup",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.zacgibson.handsuplive",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "handsup needs camera access to record festival clips.",
        "NSPhotoLibraryUsageDescription": "handsup needs access to your photo library to select videos.",
        "NSPhotoLibraryAddUsageDescription": "handsup saves festival clips to your camera roll.",
        "NSMicrophoneUsageDescription": "handsup needs microphone access to record festival clips with audio.",
        "NSLocationWhenInUseUsageDescription": "handsup uses your location to show nearby festivals.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.handsup.live",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "handsuplive.com",
              "pathPrefix": "/clip"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1a0a2e"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow handsup to access your photo library to select videos.",
          "cameraPermission": "Allow handsup to use the camera to record festival clips.",
          "microphonePermission": "Allow handsup to use the microphone to record festival clips with audio."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow handsup to save festival clips to your camera roll.",
          "savePhotosPermission": "Allow handsup to save festival clips to your camera roll.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d8b55617-a745-4060-8638-c2fc36082c29"
      }
    }
  }
}
